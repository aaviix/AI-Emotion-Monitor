# AI Emotion Monitor - Environment Configuration
# Copy this file to .env and customize values for your environment

# === Model Configuration ===
MODEL_PATH=./models/emotion_model_cnn_improved.pth
DEVICE=cpu # Options: 'cpu' or 'cuda' (for GPU acceleration)

# === Flask API Configuration ===
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=true

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# === Inference Configuration ===
ENABLE_SMOOTHING=true
SMOOTHING_WINDOW=8 # Number of frames for temporal smoothing (reduces label flickering)

ENABLE_CALIBRATION=true

# === Clinical Calibration Defaults ===
DEFAULT_SAD_BOOST=2.5 # Sensitivity multiplier for Sadness detection (1.0-5.0)
DEFAULT_ANGER_BOOST=2.0 # Sensitivity multiplier for Anger detection (1.0-5.0)
DEFAULT_NEUTRAL_SUPPRESS=0.3 # Suppression factor for Neutral emotion (0.0-1.0)

# === Face Detection Configuration ===
FACE_SCALE_FACTOR=1.1
FACE_MIN_NEIGHBORS=7
FACE_MIN_SIZE=60 # Minimum face size in pixels

# === CLAHE Configuration ===
CLAHE_CLIP_LIMIT=2.0 # Contrast limiting threshold
CLAHE_TILE_GRID_SIZE=8 # Grid size for histogram equalization

# === Session Configuration ===
SESSION_TIMEOUT_MINUTES=60 # Inactive session timeout
MAX_ACTIVE_SESSIONS=100 # Maximum concurrent sessions
